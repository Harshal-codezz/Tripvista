<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>TripVista Backend</display-name>
    <description>Java Servlet Backend for TripVista Travel Booking Platform</description>

    <!-- ========== CORS Filter ========== -->
    <filter>
        <filter-name>CORSFilter</filter-name>
        <filter-class>com.tripvista.filter.CORSFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CORSFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- ========== Servlet Mappings ========== -->

    <!-- Authentication -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.tripvista.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/api/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.tripvista.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/api/register</url-pattern>
    </servlet-mapping>

    <!-- Search Servlets -->
    <servlet>
        <servlet-name>FlightSearchServlet</servlet-name>
        <servlet-class>com.tripvista.servlet.FlightSearchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FlightSearchServlet</servlet-name>
        <url-pattern>/api/flights</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>HotelSearchServlet</servlet-name>
        <servlet-class>com.tripvista.servlet.HotelSearchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HotelSearchServlet</servlet-name>
        <url-pattern>/api/hotels</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TrainSearchServlet</servlet-name>
        <servlet-class>com.tripvista.servlet.TrainSearchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TrainSearchServlet</servlet-name>
        <url-pattern>/api/trains</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BusSearchServlet</servlet-name>
        <servlet-class>com.tripvista.servlet.BusSearchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BusSearchServlet</servlet-name>
        <url-pattern>/api/buses</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PackageSearchServlet</servlet-name>
        <servlet-class>com.tripvista.servlet.PackageSearchServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PackageSearchServlet</servlet-name>
        <url-pattern>/api/packages</url-pattern>
    </servlet-mapping>

    <!-- Booking -->
    <servlet>
        <servlet-name>BookingServlet</servlet-name>
        <servlet-class>com.tripvista.servlet.BookingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BookingServlet</servlet-name>
        <url-pattern>/api/bookings</url-pattern>
    </servlet-mapping>

    <!-- Newsletter -->
    <servlet>
        <servlet-name>NewsletterServlet</servlet-name>
        <servlet-class>com.tripvista.servlet.NewsletterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>NewsletterServlet</servlet-name>
        <url-pattern>/api/newsletter</url-pattern>
    </servlet-mapping>

</web-app>
